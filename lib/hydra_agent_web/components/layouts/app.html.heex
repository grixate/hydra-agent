<header id="hydra-app-header" class="hx-material sticky top-0 z-30 border-x-0 border-t-0">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-5">
    <a href="/" class="text-sm font-semibold text-zinc-950">Hydra</a>
    <nav class="flex items-center gap-5 text-sm text-zinc-600">
      <a href="/" class="hover:text-zinc-950">Runtime</a>
      <a href="/control" class="hover:text-zinc-950">Control</a>
      <a href="/api/health" class="hover:text-zinc-950">Health</a>
    </nav>
  </div>
</header>
<main id="hydra-app-main" class="px-4 py-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <.flash_group flash={@flash} />
    {@inner_content}
  </div>
</main>
